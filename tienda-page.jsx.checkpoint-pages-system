// Tienda Sensorial — Chapbook
// Copy verbatim from indomitocafe.com/objetos. The live site is a
// "coming soon" announcement — lean into that. Big quiet spread,
// mostly air, a chapter numbering for eventual product capsules,
// a waitlist moment instead of a catalog.

const TT = INDOMITO_TOKENS;

// ── Cover ─────────────────────────────────────────────────────
function TiendaCover() {
  return (
    <header style={{margin:'0 48px', padding:'80px 0 120px',
                    borderTop:`1px solid ${TT.ink}`, borderBottom:`1px solid ${TT.ink}`,
                    textAlign:'center'}}>
      <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.22em', marginBottom:28, fontSize:15}}>
        Mmxxvi · Próxima apertura
      </div>
      <h1 style={{fontFamily:TT.display, fontSize:'clamp(72px, 14vw, 220px)', fontWeight:300, margin:0,
                  letterSpacing:'-0.05em', lineHeight:.82}}>
        Tienda<br/><em style={{fontStyle:'italic', fontWeight:300}}>Sensorial</em>
      </h1>
      <div style={{maxWidth:620, margin:'56px auto 0', fontFamily:TT.display, fontSize:18, lineHeight:1.65, color:'rgb(26,26,25)', whiteSpace:'pre-line'}}>
        {`Objetos que acompañan la pausa.\nEdiciones limitadas, ritual como estética.`}
      </div>
      <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', fontWeight:600, fontSize:12, marginTop:36, letterSpacing:'.18em'}}>
        Tienda · Indómito Café · Buenos Aires
      </div>
    </header>
  );
}

// ── Section head (matches Club/Carta) ─────────────────────────
function TiendaSectionHead({ num, label, title }) {
  return (
    <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72,
                 padding:'120px 0 48px',
                 borderBottom:`1px solid ${TT.rule}`, marginBottom:48,
                 alignItems:'end'}}>
      <h2 style={{fontFamily:TT.display, fontSize:'clamp(48px, 6vw, 88px)', margin:0, fontWeight:400,
                  letterSpacing:'-0.04em', lineHeight:.95}}>
        {title}
      </h2>
      <div style={{paddingBottom:16}}>
        <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.22em', marginBottom:10}}>
          {num} · {label}
        </div>
      </div>
    </div>
  );
}

// ── Intermission pull-quote ───────────────────────────────────
function TiendaIntermission({ line1, line2, foot }) {
  return (
    <section style={{padding:'140px 48px'}}>
      <div style={{maxWidth:860, margin:'0 auto', textAlign:'center'}}>
        <p style={{fontFamily:TT.display, fontSize:'clamp(32px, 4vw, 52px)', fontWeight:400,
                   letterSpacing:'-0.028em', lineHeight:1.15, margin:0}}>
          <span style={{color:TT.taupe, fontStyle:'italic'}}>{line1}</span><br/>
          {line2}
        </p>
        {foot && (
          <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', fontWeight:600, fontSize:12, marginTop:28, letterSpacing:'.18em'}}>
            {foot}
          </div>
        )}
      </div>
    </section>
  );
}

// ── Capsule preview — empty placeholder, titled by category ──
function Capsule({ idx, title, caption, note }) {
  return (
    <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72,
                 padding:'48px 0 56px', borderBottom:`1px dotted ${TT.rule}`,
                 alignItems:'start'}}>
      <div>
        <div style={{display:'flex', alignItems:'baseline', gap:16, marginBottom:22}}>
          <span className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:TT.inkMuted}}>{String(idx).padStart(2,'0')}</span>
          <h3 style={{fontFamily:TT.display, fontSize:40, margin:0, fontWeight:500,
                      letterSpacing:'-0.028em', lineHeight:1}}>
            {title}
          </h3>
        </div>
        <p style={{fontSize:16, lineHeight:1.65, margin:'0 0 24px', color:TT.ink, maxWidth:560}}>
          {caption}
        </p>
        {/* Empty frame — placeholder for the unreleased object */}
        <div style={{
          aspectRatio:'4/5', maxWidth:420, background:TT.bgAlt,
          border:`1px solid ${TT.rule}`,
          display:'flex', alignItems:'center', justifyContent:'center',
          position:'relative',
        }}>
          <div style={{textAlign:'center'}}>
            <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.22em', marginBottom:8}}>
              No. {String(idx).padStart(3,'0')}
            </div>
            <div style={{fontFamily:TT.display, fontSize:14, fontStyle:'italic', color:TT.inkMuted}}>
              en preparación
            </div>
          </div>
          {/* corner marks — editorial registration crosses */}
          {['0 0', '100% 0', '0 100%', '100% 100%'].map((pos,i) => (
            <span key={i} style={{
              position:'absolute',
              [i<2?'top':'bottom']: -1,
              [i%2===0?'left':'right']: -1,
              width:16, height:16,
              borderTop: i<2 ? `1px solid ${TT.ink}` : 'none',
              borderBottom: i>=2 ? `1px solid ${TT.ink}` : 'none',
              borderLeft: i%2===0 ? `1px solid ${TT.ink}` : 'none',
              borderRight: i%2===1 ? `1px solid ${TT.ink}` : 'none',
            }}/>
          ))}
        </div>
      </div>
      <div style={{paddingTop:12, borderTop:`1px solid ${TT.rule}`, maxWidth:320}}>
        <div style={{marginBottom:22}}>
          <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.14em', marginBottom:6}}>Tirada</div>
          <div style={{fontFamily:TT.display, fontSize:18, letterSpacing:'-0.018em'}}>
            Edición limitada
          </div>
        </div>
        <div style={{marginBottom:22}}>
          <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.14em', marginBottom:6}}>Estado</div>
          <div style={{fontFamily:TT.display, fontSize:18, letterSpacing:'-0.018em'}}>
            {note}
          </div>
        </div>
      </div>
    </div>
  );
}

// ── Waitlist — the closest thing to a CTA ────────────────────
function Waitlist() {
  return (
    <section style={{padding:'0 48px 140px'}}>
      <TiendaSectionHead num="III" label="Acceso anticipado" title="Avisame cuando abra."/>
      <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72, alignItems:'start'}}>
        <div>
          <p style={{fontFamily:TT.display, fontSize:36, fontWeight:400,
                     letterSpacing:'-0.022em', lineHeight:1.25, margin:'0 0 32px', maxWidth:640}}>
            <span style={{color:TT.taupe}}>Las ediciones son chicas</span>{' '}
            y se reservan antes de salir.
          </p>
          <p style={{fontSize:17, lineHeight:1.65, margin:'0 0 32px', maxWidth:560, color:TT.ink}}>
            Dejá tu correo y te escribimos una sola vez, cuando la primera
            pieza esté lista. Sin listas de difusión. Sin ruido.
          </p>
          <form onSubmit={(e)=>e.preventDefault()} style={{display:'flex', gap:0, maxWidth:520, borderBottom:`1px solid ${TT.ink}`, paddingBottom:10}}>
            <input type="email" placeholder="tu@correo.com" style={{
              flex:1, border:0, background:'transparent',
              fontFamily:TT.body, fontSize:18, color:TT.ink,
              padding:'12px 0', outline:'none',
            }}/>
            <button type="submit" className="idm-btn idm-btn--solid" style={{padding:'12px 24px', fontSize:14}}>
              Sumarme →
            </button>
          </form>
          <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.14em', marginTop:14}}>
            Lista silenciosa · Un aviso único por apertura
          </div>
        </div>
        <div style={{paddingTop:12, borderTop:`1px solid ${TT.rule}`}}>
          <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.14em', marginBottom:10}}>Mientras tanto</div>
          <div style={{fontFamily:TT.display, fontSize:22, letterSpacing:'-0.018em', lineHeight:1.25, marginBottom:22}}>
            Pasá por la barra.<br/>Ya hay totes a la venta en Caballito.
          </div>
          <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:TT.inkMuted, letterSpacing:'.14em', lineHeight:1.7}}>
            Whatsapp · +54 9 11 60 46 39 80<br/>
            Instagram · @indomito_cafe
          </div>
        </div>
      </div>
    </section>
  );
}

// ── Page ──────────────────────────────────────────────────────
function TiendaPage() {
  const capsules = [
    { t:'Remeras',     c:'Algodón pesado, peinado. Serigrafía de un solo color. Cuello redondo, caída clásica.', n:'Primer lote · invierno' },
    { t:'Totebags',    c:'Lona cruda, costura reforzada. Asa larga para el hombro. Una sola estampa por edición.', n:'Muestra · en ajuste' },
    { t:'Cuadernos',   c:'Tapas rígidas, hojas Munken. Registrados a mano. Para el diario de la tarde.', n:'Prototipo · taller' },
    { t:'Archivo LP',  c:'Selecciones de vinilo que rotan en la barra. Algunas ediciones se liberan en pares.', n:'Curaduría abierta' },
  ];

  return (
    <div className="idm-root" style={{width:'100%', background:TT.bg}}>
      <IndomitoNav/>
      <TiendaCover/>

      {/* I — Qué estamos preparando */}
      <section style={{padding:'0 48px'}}>
        <TiendaSectionHead num="I" label="Qué estamos preparando" title="Objetos que sostienen el ritual."/>
        <p style={{maxWidth:720, fontSize:17, lineHeight:1.65, color:TT.inkSoft, margin:'0 0 56px'}}>
          La Tienda Sensorial no es un e-commerce — es un archivo lento.
          Cuatro cápsulas por año, cada una con una intención precisa.
        </p>
        {capsules.map((c, i) => (
          <Capsule key={c.t} idx={i+1} title={c.t} caption={c.c} note={c.n}/>
        ))}
      </section>

      {/* Intermission */}
      <TiendaIntermission
        line1="Diseño sensible,"
        line2="ediciones limitadas."
        foot="Tienda Sensorial · Indómito Café"
      />

      {/* II — Cómo sale */}
      <section style={{padding:'0 48px'}}>
        <TiendaSectionHead num="II" label="Cómo se libera" title="Pocas piezas, un aviso."/>
        <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72, alignItems:'start'}}>
          <div style={{fontSize:17, lineHeight:1.75, color:TT.ink, maxWidth:620}}>
            <p style={{margin:'0 0 16px'}}>
              Cada cápsula se produce en una tirada chica, numerada.
              Se reserva antes de que la pieza llegue al salón.
            </p>
            <p style={{margin:'0 0 16px'}}>
              Quienes están en la lista silenciosa reciben un aviso
              único cuando abre. El resto pasa por el salón.
            </p>
            <p style={{margin:0, color:TT.inkSoft}}>
              No hay reposiciones. Lo que queda, queda.
            </p>
          </div>
          <div style={{paddingTop:12, borderTop:`1px solid ${TT.rule}`}}>
            {[
              { k:'01 Diseño',     v:'Taller interno · 2 meses' },
              { k:'02 Muestra',    v:'Prototipo en el salón' },
              { k:'03 Aviso',      v:'Correo a la lista silenciosa' },
              { k:'04 Liberación', v:'Salón + reservas online' },
            ].map((r,i) => (
              <div key={i} style={{display:'grid', gridTemplateColumns:'1fr auto', gap:20, padding:'18px 0', borderBottom:`1px dotted ${TT.rule}`, alignItems:'baseline'}}>
                <div className="idm-mono" style={{fontFamily:'"JetBrains Mono", ui-monospace, monospace', color:'#8B6F47', letterSpacing:'.14em'}}>{r.k}</div>
                <div style={{fontFamily:TT.display, fontSize:17, letterSpacing:'-0.018em'}}>{r.v}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <Waitlist/>
      <IndomitoFooter/>
    </div>
  );
}

Object.assign(window, { TiendaPage, TiendaCover, TiendaSectionHead, TiendaIntermission, Capsule });
