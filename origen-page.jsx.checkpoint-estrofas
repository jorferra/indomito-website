// ── Estrofa ───────────────────────────────────────────────────
function Estrofa({ num, label, quiet, loud, foot, noBreak, cta, ctaHref }) {
  return (
    <section style={{padding:'0 48px'}}>
      <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72,
                   padding:'120px 0 32px',
                   borderBottom:`1px solid ${TT.rule}`, marginBottom:56, alignItems:'end'}}>
        <h2 style={{fontFamily:TT.display, fontSize:'clamp(48px, 6vw, 88px)', margin:0, fontWeight:400,
                    letterSpacing:'-0.04em', lineHeight:.95}}>
          {label}
        </h2>
        <div style={{paddingBottom:16}}>
          <div className="idm-mono" style={{fontFamily:mono, color:monoColor, letterSpacing:'.22em'}}>
            {num}
          </div>
        </div>
      </div>
      <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72, paddingBottom:80}}>
        <div>
          <p style={{fontFamily:TT.display, fontSize:'clamp(32px, 4vw, 48px)', fontWeight:400,
                     letterSpacing:'-0.025em', lineHeight:1.2, margin:'0 0 32px', maxWidth:680, whiteSpace:'pre-line'}}>
            <span style={{color:TT.taupe, fontStyle:'italic'}}>{quiet}</span>
            {loud ? (noBreak ? ' ' : '\n') : ''}{loud}
          </p>
          {foot && (
            <div className="idm-mono" style={{fontFamily:mono, color:monoColor, letterSpacing:'.14em', opacity:.7}}>
              {foot}
            </div>
          )}
          {cta && (
            <div style={{marginTop:32}}>
              <a href={ctaHref || 'https://wa.me/5491160463980'} className="idm-hover-underline"
                 style={{fontFamily:TT.display, fontSize:17, fontWeight:500,
                         color:TT.ink, textDecoration:'none', letterSpacing:'-0.015em'}}>
                {cta} →
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  );
}

