// ── Page ──────────────────────────────────────────────────────
function OrigenPage() {
  return (
    <div className="idm-root" style={{width:'100%', background:TT.bg}}>
      <IndomitoNav/>
      <OrigenCover/>

      <Estrofa
        num="I"
        label="El principio."
        quiet="Entre vinilos, cafés, silencios y charlas"
        loud="que pedían más tiempo que likes."
      />

      <Estrofa
        num="II"
        label="La práctica."
        quiet="Un lugar donde el café se habita."
        loud="Indómito es una comunidad. Una pausa real."
        noBreak
      />

      <Estrofa
        num="III"
        label="El café."
        quiet="Origen. Variedad. Proceso. Altitud."
        loud="El café que servimos tiene trazabilidad. Cada lote es una decisión."
        cta="Preguntanos qué hay hoy"
      />

      <OrigenColophon/>
