// ── Upcoming event spread ─────────────────────────────────────
function EventSpread({ code, title, date, tagline, lede, strong, cta, price, ctaState='abierto' }) {
  const isList = ctaState === 'lista';
  const isSoldOut = ctaState === 'sold out';

  return (
    <section style={{padding:'0 48px 80px'}}>
      <div style={{display:'grid', gridTemplateColumns:'1.4fr 1fr', gap:72}}>

        {/* Left — narrative */}
        <div>
          <div className="idm-mono" style={{fontFamily:mono, color:monoColor, letterSpacing:'.22em', marginBottom:20, fontSize:12, fontWeight:600}}>
            {code}
          </div>
          <h3 style={{fontFamily:ET.display, fontSize:'clamp(40px, 6vw, 72px)', fontWeight:400, margin:'0 0 12px',
                      letterSpacing:'-0.035em', lineHeight:.98}}>
            {title}
          </h3>
          <div className="idm-mono" style={{fontFamily:mono, color:monoColor, letterSpacing:'.18em', marginBottom:32, fontSize:12, fontWeight:600}}>
            {date}
          </div>
          {(tagline || lede.length > 0) && (
            <p style={{fontFamily:ET.display, fontSize:20, fontWeight:400,
                       letterSpacing:'-0.02em', lineHeight:1.5, margin:'0 0 28px', maxWidth:560}}>
              {tagline && <span style={{color:ET.taupe, fontStyle:'italic'}}>{tagline}{' '}</span>}
              {lede[0]}
            </p>
          )}
          {lede.slice(1).map((l,i) => (
            <p key={i} style={{fontFamily:ET.display, fontSize:18, lineHeight:1.6,
                               margin:'0 0 14px', maxWidth:540}}>{l}</p>
          ))}
          {strong && (
            <div style={{marginTop:32, maxWidth:540}}>
              <div className="idm-mono" style={{fontFamily:mono, color:monoColor,
                                                 letterSpacing:'.18em', fontSize:10, marginBottom:10, opacity:.7}}>
                progresión musical
              </div>
              <div style={{padding:'16px 0',
                           borderTop:`1px solid ${ET.rule}`, borderBottom:`1px solid ${ET.rule}`,
                           fontFamily:mono, fontSize:13, fontWeight:600, letterSpacing:'.12em', color:monoColor}}>
                {strong}
              </div>
            </div>
          )}
        </div>

        {/* Right — CTA */}
        <div style={{paddingTop:4}}>
          <div style={{borderTop:`1px solid ${ET.ink}`, paddingTop:24}}>
            <div className="idm-mono" style={{fontFamily:mono, color:monoColor, letterSpacing:'.2em', fontSize:11, fontWeight:600, marginBottom:10}}>
              {cta}
            </div>
            <a href="https://wa.me/5491160463980" className="idm-hover-underline"
               style={{fontFamily:ET.display, fontSize:20, fontWeight:500, color:ET.ink, textDecoration:'none', letterSpacing:'-0.015em'}}>
              {isList ? 'Anotarme →' : 'Reservar →'}
            </a>
            <div className="idm-mono" style={{fontFamily:mono,
                                               color:isSoldOut ? '#a33' : monoColor,
                                               letterSpacing:'.14em', fontSize:11, marginTop:12}}>
              · {isSoldOut ? 'sold out' : isList ? 'fecha por confirmar' : price ? `$${price} · cupos limitados` : 'cupos limitados'}
            </div>
            {!isSoldOut && (
              <a href="Indomito Cafe - Club.html" className="idm-hover-underline"
                 style={{fontFamily:mono, fontSize:11, color:monoColor, textDecoration:'none',
                         letterSpacing:'.14em', marginTop:8, display:'block'}}>
                · miembros del Club reservan 72hs antes →
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  );
}

