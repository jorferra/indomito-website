// Shared visual system for Indómito Café
// ──────────────────────────────────────────
// Palette: warm off-white, espresso, taupe, sand.
// Type: Inter Tight (display), Inter (body), JetBrains Mono (metadata).
// All tokens are declared once and reused in V1/V2.

// ── Mobile hook ────────────────────────────────────────────
function useIsMobile(breakpoint = 768) {
  const [isMobile, setIsMobile] = React.useState(
    typeof window !== 'undefined' && window.innerWidth < breakpoint
  );
  React.useEffect(() => {
    const fn = () => setIsMobile(window.innerWidth < breakpoint);
    window.addEventListener('resize', fn);
    return () => window.removeEventListener('resize', fn);
  }, [breakpoint]);
  return isMobile;
}

const INDOMITO_TOKENS = {
  bg: '#f4f1ec',
  bgAlt: '#ece7de',
  ink: '#2a2724',
  inkSoft: 'rgba(42,39,36,0.66)',
  inkMuted: 'rgba(42,39,36,0.42)',
  rule: 'rgba(42,39,36,0.14)',
  taupe: '#8a7a65',
  sand: '#c9bfae',
  cream: '#e8e1d3',
  // type — resolved via CSS custom properties so Tweaks can swap at runtime.
  display: 'var(--idm-display, "Figtree", "Helvetica Neue", Helvetica, Arial, sans-serif)',
  body: 'var(--idm-body, "Figtree", "Helvetica Neue", Helvetica, Arial, sans-serif)',
  mono: 'var(--idm-mono, "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace)',
  // Wordmark — real brand is Address Sans Pro (commercial). Archivo is a
  // close Google-Fonts stand-in; swap to Address Sans Pro once licensed.
  wordmark: '"Address Sans Pro", "Archivo", "Helvetica Neue", Helvetica, Arial, sans-serif',
};

// Shared stylesheet — injected once.
if (typeof document !== 'undefined' && !document.getElementById('indomito-shared')) {
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500;600&display=swap';
  document.head.appendChild(link);

  // Default font stacks (overridden by Tweaks via root CSS vars).
  const rootVars = document.createElement('style');
  rootVars.id = 'indomito-fontvars';
  rootVars.textContent = `:root{
    --idm-display:"Figtree","Helvetica Neue",Helvetica,Arial,sans-serif;
    --idm-body:"Figtree","Helvetica Neue",Helvetica,Arial,sans-serif;
    --idm-mono:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
  }`;
  document.head.appendChild(rootVars);

  const s = document.createElement('style');
  s.id = 'indomito-shared';
  s.textContent = `
    .idm-root{
      font-family:${INDOMITO_TOKENS.body};
      color:${INDOMITO_TOKENS.ink};
      background:${INDOMITO_TOKENS.bg};
      font-weight:400;
      -webkit-font-smoothing:antialiased;
      letter-spacing:-0.005em;
    }
    .idm-display{font-family:${INDOMITO_TOKENS.display};font-weight:400;letter-spacing:-0.028em;line-height:0.98}
    .idm-mono{font-family:${INDOMITO_TOKENS.mono};font-weight:400;font-size:11px;letter-spacing:0.02em;text-transform:uppercase}
    .idm-label{font-family:${INDOMITO_TOKENS.mono};font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:${INDOMITO_TOKENS.inkSoft};}
    .idm-rule{border:0;border-top:1px solid ${INDOMITO_TOKENS.rule};margin:0}
    .idm-underline{background-image:linear-gradient(currentColor,currentColor);background-position:0 100%;background-repeat:no-repeat;background-size:100% 1px}
    .idm-hover-underline{position:relative;display:inline-block}
    .idm-hover-underline::after{content:"";position:absolute;left:0;right:0;bottom:-2px;height:1px;background:currentColor;transform:scaleX(0);transform-origin:left;transition:transform .3s ease}
    .idm-hover-underline:hover::after{transform:scaleX(1)}
    /* filtered photographic placeholder — warm-desaturated "photo" look */
    .idm-photo{
      position:relative;overflow:hidden;background:${INDOMITO_TOKENS.cream};
      isolation:isolate;
    }
    .idm-photo:has(>img)::before{display:none}
    .idm-photo:has(>img)::after{
      background:linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,.25) 100%);
      mix-blend-mode:normal;opacity:1;
    }
    .idm-photo::before{
      content:"";position:absolute;inset:0;
      background:
        radial-gradient(110% 80% at 30% 25%, rgba(255,240,215,.85), rgba(255,240,215,0) 60%),
        radial-gradient(90% 70% at 75% 80%, rgba(58,44,30,.55), rgba(58,44,30,0) 65%),
        linear-gradient(140deg, #cdbfa4 0%, #9a8872 45%, #4f4335 100%);
      filter:saturate(.55) contrast(.95);
    }
    .idm-photo::after{
      content:"";position:absolute;inset:0;
      background-image:
        repeating-linear-gradient(0deg, rgba(0,0,0,.04) 0 1px, transparent 1px 3px),
        repeating-linear-gradient(90deg, rgba(255,255,255,.02) 0 1px, transparent 1px 3px);
      mix-blend-mode:overlay;opacity:.7;pointer-events:none;
    }
    .idm-photo>*{position:relative;z-index:2}

    /* tonal variants */
    .idm-photo--beans::before{
      background:
        radial-gradient(80% 60% at 40% 30%, rgba(255,230,195,.7), rgba(255,230,195,0) 60%),
        linear-gradient(150deg,#6b4a2e 0%, #3a2512 60%, #20140a 100%);
      filter:saturate(.6) contrast(1);
    }
    .idm-photo--milk::before{
      background:
        radial-gradient(100% 70% at 55% 40%, rgba(255,250,235,.9), rgba(255,250,235,0) 60%),
        linear-gradient(160deg,#e8dfce 0%, #b8a98c 55%, #6e5e45 100%);
      filter:saturate(.5) contrast(.95);
    }
    .idm-photo--interior::before{
      background:
        radial-gradient(80% 60% at 30% 30%, rgba(255,220,170,.8), rgba(255,220,170,0) 55%),
        linear-gradient(145deg,#a8957a 0%, #5c4a36 55%, #2a1e12 100%);
      filter:saturate(.55) contrast(.95);
    }
    .idm-photo--hands::before{
      background:
        radial-gradient(90% 70% at 60% 35%, rgba(255,235,205,.75), rgba(255,235,205,0) 60%),
        linear-gradient(160deg,#c9b294 0%, #836a4f 55%, #3a2a1c 100%);
      filter:saturate(.55) contrast(.95);
    }
    .idm-photo--portrait::before{
      background:
        radial-gradient(70% 50% at 50% 35%, rgba(255,230,200,.8), rgba(255,230,200,0) 60%),
        linear-gradient(175deg,#b39d82 0%, #5e4a34 60%, #1c140c 100%);
      filter:saturate(.55) contrast(1);
    }
    .idm-photo--steam::before{
      background:
        radial-gradient(60% 50% at 50% 60%, rgba(255,248,230,.9), rgba(255,248,230,0) 60%),
        linear-gradient(160deg,#ddd1b8 0%, #a08c6d 60%, #4a3a26 100%);
      filter:saturate(.45) contrast(.9);
    }
    .idm-photo--event::before{
      background:
        radial-gradient(80% 60% at 50% 40%, rgba(255,210,170,.7), rgba(255,210,170,0) 60%),
        linear-gradient(150deg,#8a6f52 0%, #3d2a18 55%, #130c06 100%);
      filter:saturate(.55) contrast(1);
    }

    .idm-photo-caption{
      position:absolute;left:16px;bottom:14px;z-index:3;
      color:rgba(255,248,235,.82);
      font-family:${INDOMITO_TOKENS.mono};
