// ── Photo placeholder ──────────────────────────────────────
// Pass `src` to use a real image; otherwise it renders a filtered
// gradient placeholder keyed by `variant`. Drop an image into the
// project (e.g. uploads/hero.jpg) and reference it as src.
function IdmPhoto({ variant='', caption, src, alt='', children, style }) {
  const cls = src
    ? 'idm-photo'
    : `idm-photo ${variant ? 'idm-photo--'+variant : ''}`;
  return (
    <div className={cls} style={{...style, background: src ? '#000' : undefined}}>
      {src && (
        <img src={src} alt={alt} style={{
          position:'absolute', inset:0, width:'100%', height:'100%',
          objectFit:'cover', zIndex:1, filter:'saturate(.9) contrast(1.02)',
        }}/>
      )}
      {caption && <div className="idm-photo-caption"><span className="dot"/>{caption}</div>}
      {children}
    </div>
  );
}

